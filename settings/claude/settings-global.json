      "Read(**/.pgpass)",
      "Read(**/*tfvars*)",
      "Bash(cat *.env*)",
      "Bash(cat */.env*)",
      "Bash(cat *secret*)",
      "Bash(cat *credential*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)",
      "Bash(cat *tfvars*)",
      "Bash(grep * .env*)",
      "Bash(head * .env*)",
      "Bash(tail * .env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(echo $*SECRET*)",
      "Bash(echo $*TOKEN*)",
      "Bash(echo $*KEY*)",
      "Bash(echo $*PASSWORD*)",
      "Bash(printenv*)",
      "Bash(env)",
      "Bash(set)",
      "Bash(export)",
      "Bash(rm -rf *)",
      "Bash(rm -r /)*",
      "Bash(git push *)"
