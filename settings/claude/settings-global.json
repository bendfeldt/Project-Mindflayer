      "Bash(git rev-parse*)",
      "Bash(git config --get*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(python --version)",
      "Bash(pip list*)",
      "Bash(pip show*)",
      "Bash(ruff check *)",
      "Bash(ruff format --check *)",
      "Bash(pytest *)"
